# Environment
.env
.env.local
.env.*.local

# Ephemeral artifacts
.local/

# Session journals (working memory; not tracked)
memory/sessions/

# Ticket recaps — intentionally local-only. Recap files may contain company
# context we don't want in version control. The /ticket-recap skill writes
# here; the skill machinery itself is tracked under .claude/skills/.
docs/*/ticket-recaps/

# Dependencies
node_modules/
__pycache__/
*.pyc
.venv/
vendor/

# OS
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp
*.swo

# Claude Code — machine-specific settings
.claude/settings.json
.claude/settings.local.json

# Build
dist/
build/
*.egg-info/
